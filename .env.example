# ─────────────────────────────────────────────────────────────────────────────
# Angel One SmartAPI Credentials
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Angel One API Key (from https://smartapi.angelbroking.com)
ANGEL_API_KEY=your_api_key_here

# Your Angel One Client Code (login ID)
ANGEL_CLIENT_CODE=your_client_code_here

# Your Angel One trading password
ANGEL_PASSWORD=your_password_here

# Base32-encoded TOTP secret (from Angel One 2FA setup)
# You can get this when you enable TOTP in your Angel One account.
ANGEL_TOTP_SECRET=your_totp_secret_here

# ─────────────────────────────────────────────────────────────────────────────
# Application Settings (optional overrides)
# ─────────────────────────────────────────────────────────────────────────────

# Port for the FastAPI server (Cloud Run injects PORT automatically)
PORT=8080

# Set to "production" to disable debug output
APP_ENV=development
